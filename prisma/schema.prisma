model NotificationDeliveryAttempt {
  id                     String                     @id @default(uuid()) @db.Uuid
  notificationDeliveryId String                     @db.Uuid
  notificationDeviceId   String?                    @db.Uuid
  targetIdentifier       String
  status                 NotificationDeliveryStatus @default(PENDING)
  attemptCount           Int                        @default(0)
  providerMessageId      String?
  providerStatusCode     Int?
  lastError              String?
  lastAttemptAt          DateTime?
  deliveredAt            DateTime?
  invalidatedAt          DateTime?
  metadata               Json?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  delivery NotificationDelivery @relation(fields: [notificationDeliveryId], references: [id], onDelete: Cascade)
  device   NotificationDevice?  @relation(fields: [notificationDeviceId], references: [id], onDelete: SetNull)

  @@unique([notificationDeliveryId, targetIdentifier])
  @@index([notificationDeviceId, status])
  @@index([status, lastAttemptAt])
}

model NotificationEmailHistory {
  id                  String           @id @default(uuid()) @db.Uuid
  notificationId      String?          @db.Uuid
  userId              String           @db.Uuid
  workspaceId         String           @db.Uuid
  contactId           String?          @db.Uuid
  type                NotificationType
  inactivitySessionId String           @db.Uuid
  sentAt              DateTime         @default(now())

  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId, type, inactivitySessionId])
  @@index([contactId, userId, inactivitySessionId])
  @@index([workspaceId, sentAt])
}

enum NotificationChannel {
  IN_APP
  DESKTOP
  MOBILE_PUSH
  EMAIL
  SOUND
  CALL_SOUND
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  SKIPPED
  FAILED
  SUPPRESSED
}

enum NotificationContactScope {
  ALL_CONTACTS
  ASSIGNED_AND_UNASSIGNED
  ASSIGNED_ONLY
  MENTIONS_ONLY
  NONE
}

enum SoundNotificationScope {
  ASSIGNED_AND_UNASSIGNED
  ASSIGNED_ONLY
  NONE
}

enum CallSoundNotificationScope {
  ASSIGNED_AND_UNASSIGNED
  ASSIGNED_ONLY
  ALL
