  message                Message?
  emailUnsubscribeTokens EmailUnsubscribeToken[]

  @@unique([workspaceId, idempotencyKey])
  @@unique([broadcastRunId, contactChannelId])
  @@index([workspaceId, broadcastRunId, status])
  @@index([workspaceId, status, createdAt])
  @@index([channelId, providerMessageId])
  @@index([contactChannelId])
}

model EmailUnsubscribeToken {
  id                   String    @id @default(uuid()) @db.Uuid
  workspaceId          String    @db.Uuid
  contactId            String    @db.Uuid
  contactChannelId     String?   @db.Uuid
  broadcastRunId       String?   @db.Uuid
  broadcastRecipientId String?   @db.Uuid
  email                String
  token                String    @unique
  status               String    @default("active")
  source               String    @default("broadcast")
  expiresAt            DateTime?
  usedAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact            Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactChannel     ContactChannel?     @relation(fields: [contactChannelId], references: [id], onDelete: SetNull)
  broadcastRun       BroadcastRun?       @relation(fields: [broadcastRunId], references: [id], onDelete: SetNull)
  broadcastRecipient BroadcastRecipient? @relation(fields: [broadcastRecipientId], references: [id], onDelete: SetNull)

