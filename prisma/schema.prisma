  integrationResourceId String?   @db.Uuid
  contactId             String?   @db.Uuid
  commerceCustomerId    String?   @db.Uuid
  provider              String
  externalCartId        String
  externalCheckoutId    String?
  status                String    @default("active")
  currency              String?
