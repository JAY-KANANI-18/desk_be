model Subscription {
  id                 String  @id @default(uuid()) @db.Uuid
  workspaceId        String  @unique
  plan               String
  status             String // trialing | active | past_due | cancelled | expired | paused | unpaid
  provider           String? // razorpay | stripe
  providerCustomerId String?
  providerSubId      String? @unique

  trialStartAt DateTime?
  trialEndAt   DateTime?

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  pendingPlan          String?
  pendingEffectiveAt   String?
  pendingProviderSubId String?

  quantity Int @default(1)

  lastRefundAmount Int?
  lastRefundStatus String? // "initiated" | "processed"
  lastRefundAt     DateTime?

  cancelAtPeriodEnd Boolean   @default(false)
  invoices          Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String
  subscriptionId    String?   @db.Uuid
  amount            Int
  currency          String    @default("INR")
  status            String // paid | failed | refunded | pending
  provider          String
  providerPaymentId String?
  providerInvoiceId String?
  metadata          Json?
  paidAt            DateTime?
  type              String    @default("subscription") // "subscription" | "addon"
  description       String?
  createdAt         DateTime  @default(now())

  @@unique([provider, providerPaymentId])
}

model SubscriptionOperation {
  id               String    @id @default(uuid()) @db.Uuid
  operationKey     String    @unique
  workspaceId      String
  provider         String    @default("razorpay")
  type             String
  status           String    @default("pending")
  oldProviderSubId String?
  newProviderSubId String?
  plan             String?
  retryCount       Int       @default(0)
  nextRetryAt      DateTime  @default(now())
  lockedAt         DateTime?
  lockExpiresAt    DateTime?
  lastError        String?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([workspaceId])
  @@index([provider, status, nextRetryAt])
  @@index([provider, status, lockExpiresAt, nextRetryAt])
  @@index([oldProviderSubId])
  @@index([newProviderSubId])
  @@map("subscription_operations")
}

model Usage {
  id          String @id @default(uuid())
  workspaceId String
  metric      String
  value       Int    @default(0)
  period      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, metric, period])
}

model Invoice {
  id             String  @id @default(uuid())
  workspaceId    String  @db.Uuid
  subscriptionId String? @db.Uuid

  // Provider
  provider          String // "razorpay" | "stripe"
  providerInvoiceId String  @unique // Razorpay invoice id or Stripe invoice id
  providerPaymentId String? // linked payment id once paid

  // Details
  type        String  @default("subscription") // "subscription" | "addon"
  description String?
  amount      Int // in paise / smallest currency unit
  amountDue   Int?
  amountPaid  Int?
  currency    String  @default("INR")
  status      String // "draft"|"open"|"paid"|"void"|"uncollectible"|"pending"

  // Dates
  invoiceDate DateTime?
  dueDate     DateTime?
  paidAt      DateTime?
  periodStart DateTime?
  periodEnd   DateTime?

  // URLs
  invoiceUrl String? // hosted invoice URL
  invoicePdf String? // PDF download URL

  // Raw
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}
