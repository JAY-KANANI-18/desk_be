model WorkflowRunStep {
  id          String    @id @default(uuid()) @db.Uuid
  runId       String    @db.Uuid
  stepId      String // matches StepConfig.id from workflow config
  stepType    String
  status      String    @default("pending") // pending | running | completed | failed | skipped
  input       Json?
  output      Json?
  error       String?
  attempts    Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([stepId])
}

// ============================================================
// TEMPLATES
// ============================================================

// WhatsApp approved templates (synced from Meta)
model WhatsAppTemplate {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @db.Uuid
  channelId      String    @db.Uuid
  name           String
  language       String
  category       String // MARKETING | UTILITY | AUTHENTICATION
  status         String // APPROVED | PENDING | REJECTED
  variables      Json // list of variable names: ["customer_name", "order_id"]
  rejectedReason String? // if rejected, the reason from Meta
  syncedAt       DateTime? // when we last synced with Meta
  metaId         String // the template ID assigned by Meta (for API calls)
  components     Json // header, body, footer, buttons — raw Meta structure
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, channelId, name, language])
  @@index([workspaceId, channelId])
}

model MetaPageTemplate {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  channelId   String    @db.Uuid
  channelType String // messenger | instagram
  type        String // persistent_menu | get_started
  payload     Json // raw payload to send to Meta for this template
  name        String
  syncedAt    DateTime? // when we last synced with Meta

  metaId String? // the template ID assigned by Meta (for API calls)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, channelId, metaId])
  @@index([workspaceId, channelId])
}

// Generic template store for email, Instagram, Messenger quick-replies, etc.
model MessageTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  channelType String // email | messenger | instagram | all
  name        String
  subject     String? // for email templates
  body        String // plain text or HTML
  variables   Json? // list of variable names: ["customer_name", "order_id"]
  category    String? // promotional | transactional | support
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, channelType])
}

// ============================================================
// BROADCAST CAMPAIGNS (enterprise send batches + analytics)
// ============================================================

model BroadcastRun {
  id                       String    @id @default(uuid()) @db.Uuid
  workspaceId              String    @db.Uuid
  name                     String
  channelId                String    @db.Uuid
  /// scheduled | running | completed | partial_failure
  status                   String    @default("completed")
  /// Snapshot of audience filters: tagIds, lifecycleId, teamId, respectMarketingOptOut
  audienceFilters          Json
  /// text | template
  contentMode              String
  templateName             String?
  templateLanguage         String?
  templateVariables        Json?
  templateSnapshot         Json?
  messageText              String?
  textPreview              String?
  audienceSnapshotStrategy String    @default("snapshot")
  dedupeKey                String?
  totalAudience            Int
  queuedCount              Int
  failedEnqueue            Int
  scheduledAt              DateTime?
  startedAt                DateTime?
  completedAt              DateTime?
  createdAt                DateTime  @default(now())
  createdById              String?   @db.Uuid

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel                Channel                 @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdBy              User?                   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messages               Message[]
  recipients             BroadcastRecipient[]
  emailUnsubscribeTokens EmailUnsubscribeToken[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, dedupeKey, createdAt])
  @@index([status, scheduledAt])
  @@index([channelId])
}

model BroadcastRecipient {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @db.Uuid
  broadcastRunId    String    @db.Uuid
  contactId         String    @db.Uuid
  contactChannelId  String    @db.Uuid
  channelId         String    @db.Uuid
  conversationId    String?   @db.Uuid
  identifier        String
  recipientName     String?
  status            String    @default("pending")
  idempotencyKey    String
  providerMessageId String?
  attempts          Int       @default(0)
  maxRetries        Int       @default(3)
  lastError         String?
  renderedText      String?
  renderedSubject   String?
  templateSnapshot  Json?
  metadata          Json?
  queuedAt          DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  unsubscribedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  broadcastRun           BroadcastRun            @relation(fields: [broadcastRunId], references: [id], onDelete: Cascade)
  contact                Contact                 @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactChannel         ContactChannel          @relation(fields: [contactChannelId], references: [id], onDelete: Cascade)
  channel                Channel                 @relation(fields: [channelId], references: [id], onDelete: Cascade)
