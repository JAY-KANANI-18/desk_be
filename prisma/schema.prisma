  cart      CommerceCart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   CommerceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([workspaceId, cartId])
  @@index([workspaceId, productId])
  @@index([workspaceId, sku])
}

// ============================================================
// OUTBOUND QUEUE
// ============================================================

// Every outbound message goes through the queue for reliability,
// retry logic, and rate-limit compliance.

model OutboundQueue {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid
  channelId   String @db.Uuid
  messageId   String @unique @db.Uuid // linked Message record

  // Who to send to
  to String // phone, PSID, IG scoped ID, email

  // Payload to send (channel-specific JSON blob)
  // WhatsApp: { messaging_product, type, text/image/template/... }
  // Messenger/Instagram: { recipient, message }
  // Email: { from, to, subject, text, html }
  payload Json

  status String @default("pending")
  // pending | sending | sent | failed | cancelled

  attempts   Int     @default(0)
  maxRetries Int     @default(3)
  lastError  String?

  scheduledAt DateTime  @default(now()) // when to send (allows scheduling)
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([workspaceId, channelId])
}

model ImportExportJob {
  id               String                @id @default(uuid()) @db.Uuid
  type             String
  entity           String
  status           ImportExportJobStatus @default(PENDING)
  tenantId         String                @db.Uuid
  fileUrl          String?
  resultUrl        String?
  totalRecords     Int                   @default(0)
  processedRecords Int                   @default(0)
  successCount     Int                   @default(0)
  failureCount     Int                   @default(0)
  errorLog         Json?
  metadata         Json?
  createdBy        String                @db.Uuid
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant        Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User      @relation("ImportExportJobCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([tenantId, entity, status, createdAt])
  @@index([createdBy, createdAt])
  @@index([type, status])
}

enum ImportExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================================
// TEAMS, WORKFLOWS, NOTIFICATIONS (stubs — already in your app)
// ============================================================

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String
  createdAt   DateTime @default(now())

  workspace  Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members    TeamMember[]
  contacts   Contact[]
  activities ConversationActivity[]
}

model TeamMember {
  id     String @id @default(uuid()) @db.Uuid
  teamId String @db.Uuid
  userId String @db.Uuid

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Workflow {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  name        String
  description String?
  createBy    String        @db.Uuid // user ID of workflow creator
  publishedAt DateTime?
  publishedBy String?       @db.Uuid // user ID of who published the workflow
  // trigger     String
  config      Json?
  status      String        @default("draft") // draft | published | archived
  createdAt   DateTime      @default(now())
  runs        WorkflowRun[]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkflowRun {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @db.Uuid
  workflowId    String    @db.Uuid
  contactId     String    @db.Uuid
  status        String    @default("running") // running | waiting | completed | failed | cancelled
  currentStepId String?
  variables     Json?     @default("{}")
  triggerData   Json?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
