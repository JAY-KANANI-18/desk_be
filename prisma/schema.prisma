}

enum UserPresenceStatus {
  ACTIVE
  OFFLINE
  AWAY
  BUSY
  DND
}

// ============================================================
// CONVERSATION ACTIVITY (add to existing schema.prisma)
// ============================================================
//
// One ConversationActivity row is written every time a
// system-level event happens on a conversation:
//   - open / close / reopen
//   - assign user / team
//   - unassign
//   - contact merged
//   - channel added to contact
//   - note / internal comment
//   - label added / removed
//   - priority changed
//   - SLA breached
//
// These are rendered inline in the chat timeline between
// real messages, exactly like Respond.io / Intercom do it.
//
// ─── Relations to add on existing models ───────────────────
//
// On Conversation model — add:
//   activities ConversationActivity[]
//
// On User model — add:
//   actorActivities    ConversationActivity[] @relation("ActivityActor")
//   subjectActivities  ConversationActivity[] @relation("ActivitySubject")
//
// On Team model — add:
//   activities ConversationActivity[]
// ============================================================

model ConversationActivity {
  id             String @id @default(uuid()) @db.Uuid
  workspaceId    String @db.Uuid
  conversationId String @db.Uuid

  eventType String

  // Who did it (null = system / automation)
  actorId   String? @db.Uuid // User who triggered this
  actorType String  @default("user") // user | system | automation | bot

  // Who was affected (for assign/unassign events)
  subjectUserId String? @db.Uuid // the agent being assigned
  subjectTeamId String? @db.Uuid // the team being assigned

  metadata Json?

  createdAt DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("ActivityActor", fields: [actorId], references: [id])
  subjectUser  User?        @relation("ActivitySubject", fields: [subjectUserId], references: [id])
  subjectTeam  Team?        @relation(fields: [subjectTeamId], references: [id])

  @@index([conversationId, createdAt])
  @@index([workspaceId])
  @@index([eventType])
}

enum StageType {
  lifecycle
  lost
}

model LifecycleStage {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  name        String    @db.VarChar(100)
  description String    @default("") @db.VarChar(500)
  emoji       String    @default("⭐") @db.VarChar(10)
  type        StageType @default(lifecycle)
  order       Int       @default(1)
  isDefault   Boolean   @default(false)
  isWon       Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  Contact[]

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@map("lifecycle_stages")
}

