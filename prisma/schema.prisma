// schema.prisma — COMPLETE OMNICHANNEL SCHEMA
// Covers: WhatsApp, Instagram, Messenger, Email (Mailgun)
// Features: messages (all types), attachments, templates, media assets,
//           outbound queue, channel credentials, contact profiles

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & ORGS
// ============================================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  emailVerifiedAt DateTime?
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  language  String?
  status    String?
  lastLoginAt DateTime?

  organizationMemberships OrganizationMember[]
  workspaceMemberships    WorkspaceMember[]
  assignedContacts        Contact[]              @relation("ContactToUser")
  messages                Message[]
  teamMembers             TeamMember[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  notificationDevices     NotificationDevice[]
  notificationDeliveries  NotificationDelivery[]
  notificationEmailHistory NotificationEmailHistory[]
  actorActivities         ConversationActivity[] @relation("ActivityActor")
  subjectActivities       ConversationActivity[] @relation("ActivitySubject")
  userActivity            UserActivity?
  broadcastRuns           BroadcastRun[]
  importExportJobs        ImportExportJob[]      @relation("ImportExportJobCreatedBy")
  authCredentials         AuthCredential[]
  authSessions            AuthSession[]
  refreshTokens           RefreshToken[]
  oauthAccounts           OAuthAccount[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  magicLinkTokens         MagicLinkToken[]
  otpCodes                OtpCode[]
  trustedDevices          TrustedDevice[]
  loginAttempts           LoginAttempt[]
  authAuditLogs           AuthAuditLog[]
  twoFactorSecrets        TwoFactorSecret[]
  backupCodes             BackupCode[]
}

model UserActivity {
  userId         String    @id @db.Uuid
  activityStatus UserPresenceStatus @default(OFFLINE)
  lastSeenAt     DateTime?
  lastActivityAt DateTime?
  lastWorkspaceId String?  @db.Uuid
  inactivitySessionId String @default(uuid()) @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AuthCredentialType {
  PASSWORD
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  MICROSOFT
  APPLE
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
  COMPROMISED
}

enum RefreshTokenStatus {
  ACTIVE
  USED
  REVOKED
  REUSED
}

enum AuthTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  MAGIC_LINK_LOGIN
  TEAM_INVITE
  EMAIL_OTP_LOGIN
  EMAIL_OTP_VERIFY
  EMAIL_OTP_RESET
  TWO_FACTOR_SETUP
  TWO_FACTOR_CHALLENGE
}

enum OtpChannel {
  EMAIL
}

enum LoginAttemptResult {
  SUCCESS
  FAILURE
  LOCKED
  CHALLENGE_REQUIRED
  BLOCKED
}

enum AuthAuditEvent {
  SIGN_UP
  SIGN_IN
  SIGN_OUT
  SESSION_REFRESH
  SESSION_REVOKED
  SESSION_REVOKED_ALL
  TOKEN_REUSE_DETECTED
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  MAGIC_LINK_SENT
  MAGIC_LINK_CONSUMED
  OTP_SENT
  OTP_VERIFIED
  OAUTH_LINKED
  OAUTH_SIGN_IN
  TEAM_INVITE_SENT
  TEAM_INVITE_ACCEPTED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  BACKUP_CODES_REGENERATED
  SUSPICIOUS_LOGIN
}

enum TwoFactorType {
  TOTP
}

model AuthCredential {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @db.Uuid
  type                  AuthCredentialType @default(PASSWORD)
  passwordHash          String?
  passwordVersion       Int                @default(1)
  passwordUpdatedAt     DateTime?
  passwordMigratedAt    DateTime?
  mustRotatePassword    Boolean            @default(false)
  failedPasswordAttempts Int               @default(0)
  lockedUntil           DateTime?
  passwordPolicyVersion Int                @default(1)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, type])
  @@index([lockedUntil])
}

model AuthSession {
  id                    String            @id @default(uuid()) @db.Uuid
  userId                String            @db.Uuid
  status                AuthSessionStatus @default(ACTIVE)
  rememberMe            Boolean           @default(false)
  sessionVersion        Int               @default(1)
  currentOrganizationId String?           @db.Uuid
  currentWorkspaceId    String?           @db.Uuid
  ipAddress             String?
  ipHash                String?
  userAgent             String?
  deviceId              String?
  deviceName            String?
  deviceFingerprintHash String?
  countryCode           String?
  region                String?
  city                  String?
  lastSeenAt            DateTime          @default(now())
  lastRefreshedAt       DateTime          @default(now())
  expiresAt             DateTime
  idleExpiresAt         DateTime
  revokedAt             DateTime?
  revokedReason         String?
  compromisedAt         DateTime?
  trustedDeviceId       String?           @db.Uuid
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedDevice TrustedDevice? @relation(fields: [trustedDeviceId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  auditLogs     AuthAuditLog[]

  @@index([userId, status, expiresAt])
  @@index([currentWorkspaceId])
  @@index([trustedDeviceId])
  @@index([deviceFingerprintHash])
  @@index([lastSeenAt])
}

model RefreshToken {
  id            String             @id @default(uuid()) @db.Uuid
  sessionId     String             @db.Uuid
  userId        String             @db.Uuid
  tokenFamilyId String             @db.Uuid
  previousTokenId String?          @db.Uuid
  status        RefreshTokenStatus @default(ACTIVE)
  tokenHash     String             @unique
  expiresAt     DateTime
  usedAt        DateTime?
  rotatedAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?
  createdByIp   String?
  lastSeenIp    String?
  userAgent     String?
  createdAt     DateTime           @default(now())

  session       AuthSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousToken RefreshToken? @relation("RefreshTokenChain", fields: [previousTokenId], references: [id], onDelete: SetNull)
  nextTokens    RefreshToken[] @relation("RefreshTokenChain")

  @@index([sessionId, status, expiresAt])
  @@index([userId, tokenFamilyId, status])
}

model OAuthAccount {
  id                    String       @id @default(uuid()) @db.Uuid
  userId                String       @db.Uuid
  provider              AuthProvider
  providerAccountId     String
  email                 String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  idTokenEncrypted      String?
  scope                 String?
  tokenType             String?
  expiresAt             DateTime?
  profile               Json?
  linkedAt              DateTime     @default(now())
  lastUsedAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
  @@index([email])
}

model EmailVerificationToken {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @db.Uuid
  email                String
  tokenHash            String           @unique
  purpose              AuthTokenPurpose @default(EMAIL_VERIFICATION)
  expiresAt            DateTime
  consumedAt           DateTime?
  requestedByIp        String?
  requestedByUserAgent String?
  createdAt            DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, email, expiresAt])
}

model PasswordResetToken {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @db.Uuid
  email                String
  tokenHash            String           @unique
  purpose              AuthTokenPurpose @default(PASSWORD_RESET)
  expiresAt            DateTime
  consumedAt           DateTime?
  requestedByIp        String?
  requestedByUserAgent String?
  createdAt            DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, email, expiresAt])
}

model MagicLinkToken {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String?          @db.Uuid
  email                String
  tokenHash            String           @unique
  purpose              AuthTokenPurpose @default(MAGIC_LINK_LOGIN)
  organizationId       String?          @db.Uuid
  workspaceId          String?          @db.Uuid
  roleSnapshot         Json?
  redirectUri          String?
  expiresAt            DateTime
  consumedAt           DateTime?
  requestedByIp        String?
  requestedByUserAgent String?
  createdAt            DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose, expiresAt])
  @@index([userId, purpose, expiresAt])
}

model OtpCode {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String?          @db.Uuid
  email                String
  channel              OtpChannel       @default(EMAIL)
  purpose              AuthTokenPurpose
  codeHash             String
  expiresAt            DateTime
  consumedAt           DateTime?
  attemptCount         Int              @default(0)
  maxAttempts          Int              @default(5)
  requestedByIp        String?
  requestedByUserAgent String?
  metadata             Json?
  createdAt            DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose, expiresAt])
  @@index([userId, purpose, expiresAt])
  @@index([purpose, createdAt])
}

model TrustedDevice {
  id                    String      @id @default(uuid()) @db.Uuid
  userId                String      @db.Uuid
  deviceKey             String      @unique
  deviceFingerprintHash String
  deviceName            String?
  platform              String?
  userAgent             String?
  firstIpAddress        String?
  lastIpAddress         String?
  firstSeenAt           DateTime    @default(now())
  lastSeenAt            DateTime    @default(now())
  trustedAt             DateTime?
  expiresAt             DateTime?
  revokedAt             DateTime?
  metadata              Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions AuthSession[]

  @@index([userId, lastSeenAt])
  @@index([deviceFingerprintHash])
}

model LoginAttempt {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String?            @db.Uuid
  email             String
  ipAddress         String?
  ipHash            String?
  userAgent         String?
  result            LoginAttemptResult
  reason            String?
  riskScore         Int                @default(0)
  requiresChallenge Boolean            @default(false)
  createdAt         DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
  @@index([result, createdAt])
}

model AuthAuditLog {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String?        @db.Uuid
  sessionId      String?        @db.Uuid
  event          AuthAuditEvent
  ipAddress      String?
  userAgent      String?
  organizationId String?        @db.Uuid
  workspaceId    String?        @db.Uuid
  metadata       Json?
  createdAt      DateTime       @default(now())

  user    User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session AuthSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([event, createdAt])
  @@index([organizationId, workspaceId, createdAt])
}

model TwoFactorSecret {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @db.Uuid
  type            TwoFactorType @default(TOTP)
  secretEncrypted String
  secretVersion   Int           @default(1)
  issuer          String        @default("Axodesk")
  label           String?
  confirmedAt     DateTime?
  enabledAt       DateTime?
  disabledAt      DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  backupCodes BackupCode[]

  @@unique([userId, type])
  @@index([userId, enabledAt])
}

model BackupCode {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  twoFactorSecretId String   @db.Uuid
  codeHash          String   @unique
  consumedAt        DateTime?
  createdAt         DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  twoFactorSecret TwoFactorSecret @relation(fields: [twoFactorSecretId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([twoFactorSecretId, consumedAt])
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  website  String?
  onboardingData Json?
  onboardingCompletedAt DateTime?

  plan      String   @default("free")
  createdAt DateTime @default(now())

  members    OrganizationMember[]
  workspaces Workspace[]
}

model OrganizationMember {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  role           String
  status         String    @default("active")
  joinedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Workspace {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  timeZone       String    @default("UTC")
  language       String    @default("en")
  dateFormat     String    @default("MM/DD/YYYY")
  timeFormat     String    @default("hh:mm A")
  notificationInactivityTimeoutSec Int @default(300)
  createdAt      DateTime  @default(now())
    onboardingDismissed  Boolean   @default(false)
  onboardingCompleted  Boolean   @default(false)
  invoices       Invoice[]

  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members                WorkspaceMember[]
  contacts               Contact[]
  conversations          Conversation[]
  messages               Message[]
  channels               Channel[]
  teams                  Team[]
  workflows              Workflow[]
  whatsAppTemplates      WhatsAppTemplate[]
  contactChannels        ContactChannel[]
  mediaAssets            MediaAsset[]
  outboundQueue          OutboundQueue[]
  messageTemplates       MessageTemplate[]
  metaPageTemplates      MetaPageTemplate[]
  conversationActivities ConversationActivity[]
  lifecycleStages        LifecycleStage[]
  tags                   Tag[]
  broadcastRuns          BroadcastRun[]
  aiSettings             WorkspaceAiSettings?
  aiPrompts              WorkspaceAiPrompt[]
  notifications          Notification[]
  notificationPreferences NotificationPreference[]
  notificationDevices    NotificationDevice[]
  notificationEmailHistory NotificationEmailHistory[]
  contactMergeRuns       ContactMergeRun[]
  importExportJobs       ImportExportJob[]
}

model WorkspaceAiSettings {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @unique @db.Uuid
  enabled         Boolean  @default(true)
  provider        String   @default("cohere")
  model           String   @default("command-a-03-2025")
  autoSuggest     Boolean  @default(false)
  smartReply      Boolean  @default(true)
  summarize       Boolean  @default(true)
  sentiment       Boolean  @default(false)
  translate       Boolean  @default(true)
  defaultLanguage String   @default("auto")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceAiPrompt {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @db.Uuid
  key          String?
  name         String
  description  String?
  kind         String
  prompt       String
  options      Json?
  isDefault    Boolean  @default(false)
  isEnabled    Boolean  @default(true)
  isActive     Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, kind, sortOrder])
  @@unique([workspaceId, key])
}

model WorkspaceMember {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @db.Uuid
  userId       String    @db.Uuid
  role         String
  status       String    @default("active")
  joinedAt     DateTime?
  availability String    @default("online")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  Contact[]

  @@unique([workspaceId, userId])
}

// ============================================================
// CONTACTS
// ============================================================

model Contact {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  company     String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lifecycleId String?  @db.Uuid
  status      String?
  /// When true, contact is excluded from marketing broadcasts (opt-out / compliance).
  marketingOptOut Boolean @default(false)
  mergedIntoContactId String? @db.Uuid
  mergedAt      DateTime?
  mergedByUserId String? @db.Uuid

  assigneeId        String?          @db.Uuid
  assignee          User?            @relation("ContactToUser", fields: [assigneeId], references: [id])
  teamId            String?          @db.Uuid
  team              Team?            @relation(fields: [teamId], references: [id])
  workspaceMemberId String?          @db.Uuid
  workspaceMember   WorkspaceMember? @relation(fields: [workspaceMemberId], references: [id])

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lifecycle       LifecycleStage?  @relation(fields: [lifecycleId], references: [id])
  mergedIntoContact Contact?       @relation("ContactMergedInto", fields: [mergedIntoContactId], references: [id])
  mergedContacts    Contact[]      @relation("ContactMergedInto")
  conversations   Conversation[]
  contactChannels ContactChannel[]
  tags            ContactTag[]
  primaryMergeRuns ContactMergeRun[] @relation("PrimaryContactMergeRuns")
  secondaryMergeRuns ContactMergeRun[] @relation("SecondaryContactMergeRuns")

  @@index([workspaceId])
  @@index([workspaceId, mergedIntoContactId])
}

model ContactMergeRun {
  id                 String   @id @default(uuid()) @db.Uuid
  workspaceId        String   @db.Uuid
  primaryContactId   String   @db.Uuid
  secondaryContactId String   @db.Uuid
  status             String   @default("completed")
  source             String?  // inbox_sidebar | dashboard | api
  confidenceScore    Int?
  reasonCodes        Json?
  resolution         Json?
  summary            Json?
  executedByUserId   String?  @db.Uuid
  createdAt          DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  primaryContact Contact @relation("PrimaryContactMergeRuns", fields: [primaryContactId], references: [id], onDelete: Cascade)
  secondaryContact Contact @relation("SecondaryContactMergeRuns", fields: [secondaryContactId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([primaryContactId])
  @@index([secondaryContactId])
}

// ============================================================
// Contact Tags (many-to-many between Contact and a Tag model)
// ============================================================

model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  color       String   @default("tag-indigo")
  emoji       String   @default("🏷️")
  description String?
  createdBy   String   @default("user")
  createdById String?  @db.Uuid
  updatedById String?  @db.Uuid

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  ContactTag[] // ✅ fix this

  @@unique([workspaceId, name])
}

model ContactTag {
  contactId String @db.Uuid
  tagId     String @db.Uuid

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

// ============================================================
// CONVERSATIONS
// ============================================================

model Conversation {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid
  contactId   String @db.Uuid

  subject String? // email subject / thread subject

  status String @default("open") // open | pending | resolved | closed

  lastMessageId  String?   @unique @db.Uuid
  lastMessageAt  DateTime?
  lastIncomingAt DateTime?

  unreadCount Int @default(0)

  slaDueAt    DateTime?
  slaBreached Boolean   @default(false)
  priority    String    @default("normal") // low | normal | high | urgent

  firstResponseAt DateTime?
  resolvedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace   Workspace              @relation(fields: [workspaceId], references: [id])
  contact     Contact                @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages    Message[]              @relation("ConversationMessages")
  lastMessage Message?               @relation("LastMessage", fields: [lastMessageId], references: [id])
  activities  ConversationActivity[]

  @@index([workspaceId])
  @@index([contactId])
  @@index([status])
}

// ============================================================
// MESSAGES
// ============================================================

model Message {
  id             String  @id @default(uuid()) @db.Uuid
  workspaceId    String  @db.Uuid
  conversationId String  @db.Uuid
  channelId      String? @db.Uuid
  channelType    String?

  // Message classification
  type String @default("text")
  // text | image | video | audio | voice | document | sticker | location |
  // contact | reaction | template | interactive | order | note | activity | email

  direction String @default("incoming")
  // incoming | outgoing

  // Text content (plain or email body)
  text    String?
  subject String? // email subject line

  // The provider-assigned message ID (for dedup & delivery tracking)
  channelMsgId String?

  // Author for outgoing agent messages
  authorId String? @db.Uuid

  // Delivery status
  status String @default("pending")
  // pending | sent | delivered | read | failed

  // For reactions: the message being reacted to
  replyToChannelMsgId String?

  // Raw provider payload (kept for debugging)
  rawPayload Json?

  // Extra structured data per message type:
  // location   → { lat, lng, name }
  // reaction   → { emoji, targetMsgId }
  // order      → { catalogId, items[] }
  // interactive → { type, title, payload }
  // email      → { htmlBody, headers, inReplyTo, references }
  metadata Json?

  broadcastRunId String?       @db.Uuid
  broadcastRun   BroadcastRun? @relation(fields: [broadcastRunId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  conversation       Conversation        @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author             User?               @relation(fields: [authorId], references: [id])
  channel            Channel?            @relation(fields: [channelId], references: [id])
  messageAttachments MessageAttachment[]
  lastMessageOf      Conversation[]      @relation("LastMessage")
  outboundQueue      OutboundQueue?

  @@index([workspaceId])
  @@index([conversationId])
  @@index([authorId])
  @@index([channelId])
  @@index([channelMsgId])
  @@index([status])
  @@index([broadcastRunId])
}

// ============================================================
// CHANNELS
// ============================================================

model Channel {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  type        String // whatsapp | instagram | messenger | email
  name        String
  identifier  String   @unique // phone_number_id | page_id | email prefix | IG account id
  status      String   @default("connected") // connected | disconnected | error
  createdAt   DateTime @default(now())

  // Encrypted credentials stored as JSON:
  // WhatsApp:  { accessToken, wabaId, phoneNumberId, appSecret, verifyToken }
  // Instagram: { accessToken, pageId, appSecret, verifyToken, igAccountId }
  // Messenger: { accessToken, pageId, appSecret, verifyToken }
  // Email:     { apiKey, domain, fromAddress, signingKey }
  credentials Json?

  // Channel-specific config (webhooks, auto-reply, etc.)
  config Json?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages        Message[]
  contactChannels ContactChannel[]
  outboundQueue   OutboundQueue[]
  broadcastRuns   BroadcastRun[]

  @@index([workspaceId])
  @@index([type, identifier])
}

// ============================================================
// MEDIA ASSETS (dedup store)
// ============================================================

// One row per unique file in storage.
// Multiple MessageAttachments can point to the same MediaAsset
// (e.g. same image forwarded in multiple conversations).

model MediaAsset {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid

  // Our stable internal storage URL
  url       String
  key       String? // storage key (for R2 lookup)
  mimeType  String
  mediaType String // image | video | audio | voice | document | sticker | gif
  filename  String?
  size      Int? // bytes

  // Provider-side ID used for dedup lookups
  externalMediaId String?

  // Which channel type this came from (helps with provider-specific re-upload logic)
  sourceChannelType String?

  createdAt DateTime @default(now())

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messageAttachments MessageAttachment[]

  @@index([workspaceId, externalMediaId])
  @@index([workspaceId, url])
}

// Maps a Contact to a specific channel identity
// (e.g. same person has WhatsApp +1234 AND Instagram ID 9876)
model ContactChannel {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid
  contactId   String @db.Uuid
  channelId   String @db.Uuid
  channelType String // whatsapp | instagram | messenger | email
  identifier  String // phone number, PSID, IG scoped ID, email address

  // Cached profile from provider (refreshed on inbound)
  displayName String?
  avatarUrl   String?
  profileRaw  Json? // full raw profile payload from provider
  lastMessageTime          BigInt?
  lastIncomingMessageTime  BigInt?
  lastCallInteractionTime  BigInt?
  messageWindowExpiry      BigInt?
  conversationWindowCategory Json?
  call_permission          Boolean?
  hasPermanentCallPermission Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channelId, identifier])
  @@index([workspaceId, identifier])
}

// ============================================================
// OUTBOUND QUEUE
// ============================================================

// Every outbound message goes through the queue for reliability,
// retry logic, and rate-limit compliance.

model OutboundQueue {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid
  channelId   String @db.Uuid
  messageId   String @unique @db.Uuid // linked Message record

  // Who to send to
  to String // phone, PSID, IG scoped ID, email

  // Payload to send (channel-specific JSON blob)
  // WhatsApp: { messaging_product, type, text/image/template/... }
  // Messenger/Instagram: { recipient, message }
  // Email: { from, to, subject, text, html }
  payload Json

  status String @default("pending")
  // pending | sending | sent | failed | cancelled

  attempts   Int     @default(0)
  maxRetries Int     @default(3)
  lastError  String?

  scheduledAt DateTime  @default(now()) // when to send (allows scheduling)
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   Channel   @relation(fields: [channelId], references: [id])
  message   Message   @relation(fields: [messageId], references: [id])

  @@index([status, scheduledAt])
  @@index([workspaceId, channelId])
}

model ImportExportJob {
  id               String                @id @default(uuid()) @db.Uuid
  type             String
  entity           String
  status           ImportExportJobStatus @default(PENDING)
  tenantId         String                @db.Uuid
  fileUrl          String?
  resultUrl        String?
  totalRecords     Int                   @default(0)
  processedRecords Int                   @default(0)
  successCount     Int                   @default(0)
  failureCount     Int                   @default(0)
  errorLog         Json?
  metadata         Json?
  createdBy        String                @db.Uuid
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant         Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser  User      @relation("ImportExportJobCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([tenantId, entity, status, createdAt])
  @@index([createdBy, createdAt])
  @@index([type, status])
}

enum ImportExportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

