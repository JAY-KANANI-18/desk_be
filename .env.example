PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axodesk
PRISMA_CONNECTION_LIMIT=5
PRISMA_POOL_TIMEOUT=10
REDIS_URL=redis://localhost:6379

AUTH_JWT_SECRET=replace-with-32-byte-secret
AUTH_ENCRYPTION_KEY=replace-with-32-byte-secret
AUTH_JWT_ISSUER=axodesk-auth
AUTH_JWT_AUDIENCE=axodesk-api
AUTH_CSRF_SECRET=replace-with-csrf-secret
AUTH_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5174

AUTH_FRONTEND_BASE_URL=http://localhost:5173
AUTH_API_BASE_URL=http://localhost:3000
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_REQUIRE_CSRF=true
AUTH_ACCEPT_SUPABASE_TOKENS=true
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/keys

AUTH_PASSWORD_MIN_LENGTH=12
AUTH_ARGON2_MEMORY_COST=19456
AUTH_ARGON2_TIME_COST=3
AUTH_ARGON2_PARALLELISM=1
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_SESSION_IDLE_TTL_SECONDS=604800
AUTH_REMEMBER_ME_TTL_SECONDS=2592000
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=15
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_INVITE_TTL_MINUTES=15
AUTH_OTP_TTL_MINUTES=10
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_OTP_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_OTP_RATE_LIMIT_WINDOW_SECONDS=600

AUTH_FROM_EMAIL=security@axodesk.com
AUTH_SMTP_HOST=localhost
AUTH_SMTP_PORT=1025
AUTH_SMTP_USER=
AUTH_SMTP_PASS=
AUTH_SMTP_SECURE=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

PUBLIC_API_BASE_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3000
INTEGRATION_WEBHOOK_BASE_URL=http://localhost:3000
INTEGRATION_JOB_WORKER_CONCURRENCY=1
INTEGRATION_ENCRYPTION_KEY=

META_APP_ID=
META_APP_SECRET=
META_ADS_REDIRECT_URI=http://localhost:3000/api/integrations/meta-ads/oauth/callback

# WhatsApp Embedded Signup / Cloud API
# Use the same Meta app as META_APP_ID/META_APP_SECRET unless WhatsApp is isolated.
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_VERIFY_TOKEN=replace-with-webhook-verify-token
WHATSAPP_REDIRECT_URI=http://localhost:3000/api/channels/whatsapp/auth/callback
WHATSAPP_EMBEDDED_SIGNUP_REDIRECT_URI=http://localhost:3000/api/channels/whatsapp/auth/embedded-signup/callback
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
WHATSAPP_HOSTED_ES_REDIRECT_URI=http://localhost:3000/api/channels/whatsapp/auth/hosted-es/callback
# Optional: set only if Meta provides a Hosted Embedded Signup launch URL for your app.
WHATSAPP_HOSTED_ES_URL=

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/integrations/shopify/oauth/callback
SHOPIFY_SCOPES=read_customers,read_products,read_orders,read_checkouts,read_all_orders 
SHOPIFY_API_VERSION=2026-04
SHOPIFY_INITIAL_SYNC_API=graphql
SHOPIFY_INITIAL_SYNC_GRAPHQL_FALLBACK=true
SHOPIFY_INITIAL_SYNC_MAX_PAGES=8
SHOPIFY_INITIAL_SYNC_PAGE_SIZE=100
SHOPIFY_WEBHOOK_BASE_URL=http://localhost:3000
SHOPIFY_WEBHOOK_SECRET=

AI_AGENTS_ENABLED=true
AI_PROVIDER=mistral
AI_MODEL=
AI_TIMEOUT_MS=20000
AI_PROVIDER_RETRIES=2
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1
AI_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_AGENT_DB_CONNECTION_LIMIT=2
AI_AGENT_DB_POOL_TIMEOUT=10
AI_AGENT_WORKER_CONCURRENCY=2
AI_AGENT_WORKER_RATE_LIMIT_MAX=60
AI_AGENT_WORKER_RATE_LIMIT_DURATION_MS=60000
AI_KNOWLEDGE_WORKER_CONCURRENCY=1
AI_KNOWLEDGE_WORKER_RATE_LIMIT_MAX=20
AI_KNOWLEDGE_WORKER_RATE_LIMIT_DURATION_MS=60000
WORKFLOW_AI_BUILDER_ENABLED=false
WORKFLOW_AI_BUILDER_MODEL=mistral-small-latest
WORKFLOW_AI_BUILDER_TIMEOUT_MS=60000

# Google Analytics 4 Measurement Protocol
GA4_ENABLED=false
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GA4_DEFAULT_CLIENT_ID=
GA4_DEBUG=false
GA4_TIMEOUT_MS=2000

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_ENABLE_LOGS=true
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1
SENTRY_PROFILE_LIFECYCLE=trace
SENTRY_SEND_DEFAULT_PII=true
SENTRY_DEBUG_ENDPOINT_ENABLED=false
